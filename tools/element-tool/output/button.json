{
  "button": {
    "description": "按钮。",
    "attributeDescriptors": [
      {
        "key": "size",
        "types": [
          "STRING"
        ],
        "default": "default",
        "required": false,
        "enums": [
          "default",
          "mini"
        ],
        "requiredInEnums": true,
        "description": "按钮的大小"
      },
      {
        "key": "type",
        "types": [
          "STRING"
        ],
        "default": "default",
        "required": false,
        "enums": [
          "primary",
          "default",
          "warn"
        ],
        "requiredInEnums": true,
        "description": "按钮的样式类型"
      },
      {
        "key": "plain",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "按钮是否镂空，背景色透明"
      },
      {
        "key": "disabled",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "是否禁用"
      },
      {
        "key": "loading",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "名称前是否带 loading 图标"
      },
      {
        "key": "form-type",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [
          "submit",
          "reset",
          "submitToGroup"
        ],
        "requiredInEnums": true,
        "description": "用于 form 组件，点击分别会触发 form 组件的 submit/reset 事件"
      },
      {
        "key": "open-type",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [
          "contact",
          "liveActivity",
          "share",
          "getPhoneNumber",
          "getRealtimePhoneNumber",
          "getUserInfo",
          "launchApp",
          "openSetting",
          "feedback",
          "chooseAvatar",
          "agreePrivacyAuthorization"
        ],
        "requiredInEnums": true,
        "description": "微信开放能力"
      },
      {
        "key": "hover-class",
        "types": [
          "STRING"
        ],
        "default": "button-hover",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "指定按钮按下去的样式类。当 hover-class=\"none\" 时，没有点击态效果"
      },
      {
        "key": "hover-stop-propagation",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "指定是否阻止本节点的祖先节点出现点击态"
      },
      {
        "key": "hover-start-time",
        "types": [
          "NUMBER"
        ],
        "default": 20,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "按住后多久出现点击态，单位毫秒"
      },
      {
        "key": "hover-stay-time",
        "types": [
          "NUMBER"
        ],
        "default": 70,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "手指松开后点击态保留时间，单位毫秒"
      },
      {
        "key": "lang",
        "types": [
          "STRING"
        ],
        "default": "en",
        "required": false,
        "enums": [
          "en",
          "zh_CN",
          "zh_TW"
        ],
        "requiredInEnums": true,
        "description": "指定返回用户信息的语言，zh_CN 简体中文，zh_TW 繁体中文，en 英文。"
      },
      {
        "key": "session-from",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "会话来源，open-type=\"contact\"时有效，长度不超过 1024 个字符"
      },
      {
        "key": "send-message-title",
        "types": [
          "STRING"
        ],
        "default": "当前标题",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "会话内消息卡片标题，open-type=\"contact\"时有效"
      },
      {
        "key": "send-message-path",
        "types": [
          "STRING"
        ],
        "default": "当前分享路径",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "会话内消息卡片点击跳转小程序路径，open-type=\"contact\"时有效"
      },
      {
        "key": "send-message-img",
        "types": [
          "STRING"
        ],
        "default": "截图",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "会话内消息卡片图片，open-type=\"contact\"时有效"
      },
      {
        "key": "app-parameter",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "打开 APP 时，向 APP 传递的参数，open-type=launchApp时有效"
      },
      {
        "key": "show-message-card",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "是否显示会话内消息卡片，设置此参数为 true，用户进入客服会话会在右下角显示\"可能要发送的小程序\"提示，用户点击后可以快速发送小程序消息，open-type=\"contact\"时有效"
      },
      {
        "key": "phone-number-no-quota-toast",
        "types": [
          "BOOLEAN"
        ],
        "default": true,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "当手机号快速验证或手机号实时验证额度用尽时，是否对用户展示“申请获取你的手机号，但该功能使用次数已达当前小程序上限，暂时无法使用”的提示，默认展示，open-type=\"getPhoneNumber\" 或 open-type=\"getRealtimePhoneNumber\" 时有效"
      },
      {
        "key": "need-show-entrance",
        "types": [
          "BOOLEAN"
        ],
        "default": true,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "转发的文本消息是否要带小程序入口"
      },
      {
        "key": "entrance-path",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "从消息小程序入口打开小程序的路径，默认为聊天工具启动路径"
      }
    ],
    "events": [
      "bindgetuserinfo",
      "bindcontact",
      "createliveactivity",
      "bindgetphonenumber",
      "bindgetrealtimephonenumber",
      "binderror",
      "bindopensetting",
      "bindlaunchapp",
      "bindchooseavatar",
      "bindagreeprivacyauthorization"
    ],
    "canOpen": false,
    "canClose": false,
    "url": "https://developers.weixin.qq.com/miniprogram/dev/component/button.html"
  }
}