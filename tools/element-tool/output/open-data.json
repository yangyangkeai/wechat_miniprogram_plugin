{
  "open-data": {
    "description": "用于展示微信开放的数据。注意：用户信息相关功能已进行调整，部分属性不再返回或展示灰色头像/默认值。",
    "attributeDescriptors": [
      {
        "key": "type",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [
          "groupName",
          "userNickName",
          "userAvatarUrl",
          "userGender",
          "userCity",
          "userProvince",
          "userCountry",
          "userLanguage"
        ],
        "requiredInEnums": true,
        "description": "开放数据类型"
      },
      {
        "key": "open-gid",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "当 type=\"groupName\" 时生效, 群id"
      },
      {
        "key": "lang",
        "types": [
          "STRING"
        ],
        "default": "en",
        "required": false,
        "enums": [
          "en",
          "zh_CN",
          "zh_TW"
        ],
        "requiredInEnums": true,
        "description": "当 type=\"user*\" 时生效，以哪种语言展示 userInfo"
      },
      {
        "key": "default-text",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "数据为空时的默认文案"
      },
      {
        "key": "default-avatar",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "用户头像为空时的默认图片，支持相对路径和网络图片路径"
      }
    ],
    "events": [
      "error"
    ],
    "canOpen": false,
    "canClose": false,
    "url": "https://developers.weixin.qq.com/miniprogram/dev/component/open-data.html"
  }
}