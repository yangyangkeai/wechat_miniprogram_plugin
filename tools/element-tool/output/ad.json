{
  "ad": {
    "description": "Banner 广告。",
    "attributeDescriptors": [
      {
        "key": "unit-id",
        "types": [
          "STRING"
        ],
        "default": null,
        "required": true,
        "enums": [],
        "requiredInEnums": true,
        "description": "广告单元id，可在小程序管理后台的流量主模块新建"
      },
      {
        "key": "ad-intervals",
        "types": [
          "NUMBER"
        ],
        "default": null,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "广告自动刷新的间隔时间，单位为秒，参数值必须大于等于30（该参数不传入时 Banner 广告不会自动刷新）"
      },
      {
        "key": "ad-type",
        "types": [
          "STRING"
        ],
        "default": "banner",
        "required": false,
        "enums": [
          "banner",
          "video",
          "grid"
        ],
        "requiredInEnums": true,
        "description": "广告类型，默认为展示banner，可通过设置该属性为video展示视频广告, grid为格子广告"
      },
      {
        "key": "ad-theme",
        "types": [
          "STRING"
        ],
        "default": "white",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": ""
      }
    ],
    "events": [
      "load",
      "error",
      "close"
    ],
    "canOpen": false,
    "canClose": false,
    "url": "https://developers.weixin.qq.com/miniprogram/dev/component/ad.html"
  }
}