{
  "live-player": {
    "description": "实时音视频播放（v2.9.1 起支持同层渲染）。",
    "attributeDescriptors": [
      {
        "key": "src",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "音视频地址。目前仅支持 flv, rtmp 格式"
      },
      {
        "key": "mode",
        "types": [
          "STRING"
        ],
        "default": "live",
        "required": false,
        "enums": [
          "live",
          "RTC"
        ],
        "requiredInEnums": true,
        "description": "模式"
      },
      {
        "key": "autoplay",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "自动播放"
      },
      {
        "key": "muted",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "是否静音"
      },
      {
        "key": "orientation",
        "types": [
          "STRING"
        ],
        "default": "vertical",
        "required": false,
        "enums": [
          "vertical",
          "horizontal"
        ],
        "requiredInEnums": true,
        "description": "画面方向"
      },
      {
        "key": "object-fit",
        "types": [
          "STRING"
        ],
        "default": "contain",
        "required": false,
        "enums": [
          "contain",
          "fillCrop"
        ],
        "requiredInEnums": true,
        "description": "填充模式，可选值有 contain，fillCrop"
      },
      {
        "key": "background-mute",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "进入后台时是否静音（已废弃，默认退后台静音）"
      },
      {
        "key": "min-cache",
        "types": [
          "NUMBER"
        ],
        "default": 1,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "最小缓冲区，单位s（RTC 模式推荐 0.2s）"
      },
      {
        "key": "max-cache",
        "types": [
          "NUMBER"
        ],
        "default": 3,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "最大缓冲区，单位s（RTC 模式推荐 0.8s）。缓冲区用来抵抗网络波动，缓冲数据越多，网络抗性越好，但时延越大。"
      },
      {
        "key": "sound-mode",
        "types": [
          "STRING"
        ],
        "default": "speaker",
        "required": false,
        "enums": [
          "speaker",
          "ear"
        ],
        "requiredInEnums": true,
        "description": "声音输出方式"
      },
      {
        "key": "auto-pause-if-navigate",
        "types": [
          "BOOLEAN"
        ],
        "default": true,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "当跳转到本小程序的其他页面时，是否自动暂停本页面的实时音视频播放"
      },
      {
        "key": "auto-pause-if-open-native",
        "types": [
          "BOOLEAN"
        ],
        "default": true,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "当跳转到其它微信原生页面时，是否自动暂停本页面的实时音视频播放"
      },
      {
        "key": "picture-in-picture-mode",
        "types": [
          "STRING",
          "ARRAY"
        ],
        "default": "",
        "required": false,
        "enums": [
          "push",
          "pop"
        ],
        "requiredInEnums": true,
        "description": "设置小窗模式： push, pop，空字符串或通过数组形式设置多种模式（如： [\"push\", \"pop\"]）"
      },
      {
        "key": "picture-in-picture-init-position",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "小窗模式下小窗的初始显示位置，格式为 (alignment, y)，其中 alignment 表示小窗吸附屏幕左侧还是右侧，可选值为 left、right，y 代表小窗最顶部所在的屏幕高度百分比"
      },
      {
        "key": "enable-system-pip",
        "types": [
          "BOOLEAN"
        ],
        "default": true,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "是否支持 iOS 系统画中画，默认支持"
      },
      {
        "key": "enable-auto-rotation",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "是否开启手机横屏时自动全屏，当系统设置开启自动旋转时生效"
      },
      {
        "key": "referrer-policy",
        "types": [
          "STRING"
        ],
        "default": "no-referrer",
        "required": false,
        "enums": [
          "origin",
          "no-referrer"
        ],
        "requiredInEnums": true,
        "description": "格式固定为 https://servicewechat.com/{appid}/{version}/page-frame.html，其中 {appid} 为小程序的 appid，{version} 为小程序的版本号，版本号为 0 表示为开发版、体验版以及审核版本，版本号为 devtools 表示为开发者工具，其余为正式版本；"
      },
      {
        "key": "enable-casting",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "是否支持投屏。开启后，可以通过 LivePlayerContext 上相关方法进行操作。"
      },
      {
        "key": "mute-on-audio-conflict",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "音频冲突时是否静音"
      }
    ],
    "events": [
      "statechange",
      "fullscreenchange",
      "netstatus",
      "audiovolumenotify",
      "enterpictureinpicture",
      "leavepictureinpicture",
      "castinguserselect",
      "castingstatechange",
      "castinginterrupt"
    ],
    "canOpen": false,
    "canClose": false,
    "url": "https://developers.weixin.qq.com/miniprogram/dev/component/live-player.html"
  }
}