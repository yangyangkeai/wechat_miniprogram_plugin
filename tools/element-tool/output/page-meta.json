{
  "page-meta": {
    "description": "页面属性配置节点，用于指定页面的一些属性、监听页面事件。只能是页面内的第一个节点。可以配合 navigation-bar 组件一同使用。通过这个节点可以获得类似于调用 wx.setBackgroundTextStyle wx.setBackgroundColor 等接口调用的效果。",
    "attributeDescriptors": [
      {
        "key": "background-text-style",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [
          "dark",
          "light"
        ],
        "requiredInEnums": true,
        "description": "下拉背景字体、loading 图的样式，仅支持 dark 和 light"
      },
      {
        "key": "background-color",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "窗口的背景色，必须为十六进制颜色值"
      },
      {
        "key": "background-color-top",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "顶部窗口的背景色，必须为十六进制颜色值，仅 iOS 支持"
      },
      {
        "key": "background-color-bottom",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "底部窗口的背景色，必须为十六进制颜色值，仅 iOS 支持"
      },
      {
        "key": "root-background-color",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "页面内容的背景色，用于页面中的空白部分和页面大小变化 resize 动画期间的临时空闲区域"
      },
      {
        "key": "page-style",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "页面根节点样式，页面根节点是所有页面节点的祖先节点，相当于 HTML 中的 body 节点"
      },
      {
        "key": "page-font-size",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [
          "system"
        ],
        "requiredInEnums": true,
        "description": "页面 page 的字体大小，可以设置为 system ，表示使用当前用户设置的微信字体大小"
      },
      {
        "key": "root-font-size",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [
          "system"
        ],
        "requiredInEnums": true,
        "description": "页面的根字体大小，页面中的所有 rem 单位，将使用这个字体大小作为参考值，即 1rem 等于这个字体大小；自小程序版本 2.11.0 起，也可以设置为 system"
      },
      {
        "key": "page-orientation",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [
          "auto",
          "portrait",
          "landscape"
        ],
        "requiredInEnums": true,
        "description": "页面的方向，可为 auto portrait 或 landscape"
      },
      {
        "key": "scroll-top",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "滚动位置，可以使用 px 或者 rpx 为单位，在被设置时，页面会滚动到对应位置"
      },
      {
        "key": "scroll-duration",
        "types": [
          "NUMBER"
        ],
        "default": 300,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "滚动动画时长"
      }
    ],
    "events": [
      "resize",
      "scroll",
      "scrolldone"
    ],
    "canOpen": false,
    "canClose": false,
    "url": "https://developers.weixin.qq.com/miniprogram/dev/component/page-meta.html"
  }
}