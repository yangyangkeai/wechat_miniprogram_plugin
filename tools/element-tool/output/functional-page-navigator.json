{
  "functional-page-navigator": {
    "description": "仅在插件中有效，用于跳转到插件功能页。",
    "attributeDescriptors": [
      {
        "key": "version",
        "types": [
          "STRING"
        ],
        "default": "release",
        "required": false,
        "enums": [
          "develop",
          "trial",
          "release"
        ],
        "requiredInEnums": true,
        "description": "跳转到的小程序版本，**线上版本必须设置为 release**"
      },
      {
        "key": "name",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [
          "loginAndGetUserInfo",
          "requestPayment",
          "chooseAddress",
          "chooseInvoice",
          "chooseInvoiceTitle"
        ],
        "requiredInEnums": true,
        "description": "要跳转到的功能页"
      },
      {
        "key": "args",
        "types": [
          "OBJECT"
        ],
        "default": null,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "功能页参数，参数格式与具体功能页相关"
      },
      {
        "key": "bindsuccess",
        "types": [
          "EVENTHANDLER"
        ],
        "default": null,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "功能页返回，且操作成功时触发， detail 格式与具体功能页相关"
      },
      {
        "key": "bindfail",
        "types": [
          "EVENTHANDLER"
        ],
        "default": null,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "功能页返回，且操作失败时触发， detail 格式与具体功能页相关"
      },
      {
        "key": "bindcancel",
        "types": [
          "EVENTHANDLER"
        ],
        "default": null,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "因用户操作从功能页返回时触发"
      }
    ],
    "events": [
      "success",
      "fail",
      "cancel"
    ],
    "canOpen": true,
    "canClose": false,
    "url": "https://developers.weixin.qq.com/miniprogram/dev/component/functional-page-navigator.html"
  }
}