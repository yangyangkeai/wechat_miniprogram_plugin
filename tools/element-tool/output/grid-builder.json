{
  "grid-builder": {
    "description": "网格构造器，仅支持作为 <scroll-view type=\"custom\"> 模式的直接子节点。具体用法可参考 scroll-view",
    "attributeDescriptors": [
      {
        "key": "padding",
        "types": [
          "ARRAY"
        ],
        "default": [
          0,
          0,
          0,
          0
        ],
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "长度为 4 的数组，按 top、right、bottom、left 顺序指定内边距"
      },
      {
        "key": "list",
        "types": [
          "ARRAY"
        ],
        "default": null,
        "required": true,
        "enums": [],
        "requiredInEnums": true,
        "description": "需要用于渲染的列表"
      },
      {
        "key": "child-count",
        "types": [
          "ARRAY"
        ],
        "default": null,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "完整列表的长度，如果不传则取 list 的长度作为其值"
      },
      {
        "key": "type",
        "types": [
          "STRING"
        ],
        "default": "aligned",
        "required": true,
        "enums": [
          "aligned",
          "masonry"
        ],
        "requiredInEnums": true,
        "description": "布局方式。aligned: 每行高度由同一行中最大高度子节点决定；masonry: 瀑布流，根据子元素高度自动布局"
      },
      {
        "key": "cross-axis-count",
        "types": [
          "NUMBER"
        ],
        "default": 2,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "交叉轴元素数量"
      },
      {
        "key": "max-cross-axis-extent",
        "types": [
          "NUMBER"
        ],
        "default": 0,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "交叉轴元素最大范围"
      },
      {
        "key": "main-axis-gap",
        "types": [
          "NUMBER"
        ],
        "default": 0,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "主轴方向间隔"
      },
      {
        "key": "cross-axis-gap",
        "types": [
          "NUMBER"
        ],
        "default": 0,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "交叉轴方向间隔"
      },
      {
        "key": "binditembuild",
        "types": [
          "EVENTHANDLE"
        ],
        "default": null,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "列表项创建时触发，event.detail = {index}，index 即被创建的列表项序号"
      },
      {
        "key": "binditemdispose",
        "types": [
          "EVENTHANDLE"
        ],
        "default": null,
        "required": false,
        "enums": [],
        "requiredInEnums": true,
        "description": "列表项回收时触发，event.detail = {index}，index 即被回收的列表项序号"
      }
    ],
    "events": [
      "itembuild",
      "itemdispose"
    ],
    "canOpen": false,
    "canClose": false,
    "url": "https://developers.weixin.qq.com/miniprogram/dev/component/grid-builder.html"
  }
}