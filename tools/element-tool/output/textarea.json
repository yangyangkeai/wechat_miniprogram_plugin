{
  "textarea": {
    "description": "多行输入框。该组件是原生组件，使用时请注意相关限制。",
    "attributeDescriptors": [
      {
        "key": "value",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "输入框的内容"
      },
      {
        "key": "placeholder",
        "types": [
          "STRING"
        ],
        "default": "",
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "输入框为空时占位符"
      },
      {
        "key": "placeholder-style",
        "types": [
          "STRING",
          "OBJECT"
        ],
        "default": "",
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "指定 placeholder 的样式。WebView下目前仅支持color,font-size,font-weight,line-height；Skyline下需传入对象，格式为 { fontSize: number, fontWeight: string, color: string }"
      },
      {
        "key": "disabled",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "是否禁用"
      },
      {
        "key": "maxlength",
        "types": [
          "NUMBER"
        ],
        "default": 140,
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "最大输入长度，设置为 -1 的时候不限制最大长度"
      },
      {
        "key": "auto-focus",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "自动聚焦，拉起键盘。"
      },
      {
        "key": "focus",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "获取焦点"
      },
      {
        "key": "auto-height",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "是否自动增高，设置auto-height时，style.height不生效"
      },
      {
        "key": "cursor-spacing",
        "types": [
          "NUMBER"
        ],
        "default": 0,
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "指定光标与键盘的距离。取textarea距离底部的距离和cursor-spacing指定的距离的最小值作为光标与键盘的距离"
      },
      {
        "key": "cursor",
        "types": [
          "NUMBER"
        ],
        "default": -1,
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "指定focus时的光标位置"
      },
      {
        "key": "selection-start",
        "types": [
          "NUMBER"
        ],
        "default": -1,
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "光标起始位置，自动聚集时有效，需与selection-end搭配使用"
      },
      {
        "key": "selection-end",
        "types": [
          "NUMBER"
        ],
        "default": -1,
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "光标结束位置，自动聚集时有效，需与selection-start搭配使用"
      },
      {
        "key": "adjust-position",
        "types": [
          "BOOLEAN"
        ],
        "default": true,
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "键盘弹起时，是否自动上推页面"
      },
      {
        "key": "hold-keyboard",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "focus时，点击页面的时候不收起键盘"
      },
      {
        "key": "disable-default-padding",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "是否去掉 iOS 下的默认内边距"
      },
      {
        "key": "confirm-type",
        "types": [
          "STRING"
        ],
        "default": "return",
        "required": false,
        "enums": [
          "send",
          "search",
          "next",
          "go",
          "done",
          "return"
        ],
        "requiredInEnums": true,
        "description": "设置键盘右下角按钮的文字"
      },
      {
        "key": "confirm-hold",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "点击键盘右下角按钮时是否保持键盘不收起"
      },
      {
        "key": "adjust-keyboard-to",
        "types": [
          "STRING"
        ],
        "default": "cursor",
        "required": false,
        "enums": [
          "cursor",
          "bottom"
        ],
        "requiredInEnums": true,
        "description": "键盘对齐位置。"
      },
      {
        "key": "placeholder-class",
        "types": [
          "STRING"
        ],
        "default": "textarea-placeholder",
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "指定 placeholder 的样式类，目前仅支持color,font-size和font-weight"
      },
      {
        "key": "fixed",
        "types": [
          "BOOLEAN"
        ],
        "default": false,
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "如果 textarea 是在一个 position:fixed 的区域，需要显示指定属性 fixed 为 true"
      },
      {
        "key": "show-confirm-bar",
        "types": [
          "BOOLEAN"
        ],
        "default": true,
        "required": false,
        "enums": [],
        "requiredInEnums": false,
        "description": "是否显示键盘上方带有”完成“按钮那一栏"
      }
    ],
    "events": [
      "focus",
      "blur",
      "linechange",
      "input",
      "confirm",
      "keyboardheightchange",
      "selectionchange",
      "keyboardcompositionstart",
      "keyboardcompositionupdate",
      "keyboardcompositionend"
    ],
    "canOpen": false,
    "canClose": false,
    "url": "https://developers.weixin.qq.com/miniprogram/dev/component/textarea.html"
  }
}